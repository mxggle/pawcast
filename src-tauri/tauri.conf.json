{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pawcast",
  "version": "1.0.0-beta.4",
  "identifier": "com.pawcast.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' customprotocol: asset:; connect-src 'self' ipc: http://ipc.localhost https: http: ws: wss:; img-src 'self' asset: http://asset.localhost data: blob: https:; media-src 'self' local-media: http://local-media.localhost blob: data: https:; frame-src https://www.youtube.com https://www.youtube-nocookie.com; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:"
    },
    "windows": [
      {
        "label": "main",
        "title": "Pawcast",
        "url": "index.html",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 16, "y": 28 }
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "category": "Education",
    "copyright": "Copyright © 2026 Pawcast",
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe", "binaries/yt-dlp"],
    "icon": ["icons/icon.png", "icons/icon.icns", "icons/icon.ico"]
  }
}
