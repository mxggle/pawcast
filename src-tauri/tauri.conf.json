{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pawcast",
  "version": "1.0.0-beta.3",
  "identifier": "com.pawcast.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 0.0.0.0",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Pawcast",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
