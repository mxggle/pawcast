{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Least-privilege permissions for Pawcast desktop windows",
  "windows": ["main", "settings", "glossary"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "opener:allow-reveal-item-in-dir"
  ]
}
